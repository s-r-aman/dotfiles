# AI — assistants, coding agents, meeting tools.
# ./bootstrap.sh --with ai
#
# 11 casks.
#
# This tier churns fastest: these casks get renamed, superseded and removed
# more often than anything else here. It is isolated so that one dead entry
# fails this tier alone instead of blocking the whole bootstrap.

# --- assistants ----------------------------------------------------------
cask "claude"
cask "chatgpt"
cask "chatgpt-atlas"

# --- coding agents / terminals -------------------------------------------
# Was installed by hand on the source machine into ~/.local/share/claude, so
# it never showed up in `brew list` and was missing from these Brewfiles.
# The cask self-updates, so its version may lag a hand-installed copy briefly.
cask "claude-code"
cask "codex"
cask "cmux"
cask "conductor"
cask "supacode"

# --- meetings ------------------------------------------------------------
cask "granola"
cask "fathom"

# --- voice / misc --------------------------------------------------------
# Also installed by hand on the source machine (dragged to /Applications), so
# it was invisible to `brew list` and absent from these Brewfiles.
# Needs Accessibility + Microphone permission before its hotkey works.
cask "wispr-flow"
cask "fluidvoice"
cask "finetune"
