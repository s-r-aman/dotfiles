theme = tokyonight 
font-size = 18
# NOTE: the family is "MonaspiceAr Nerd Font", NOT "Monaspace Argon".
# Nerd Fonts renames Monaspace to "Monaspice" when patching and abbreviates
# Argon to "Ar". The upstream name silently fails to match, and Ghostty then
# falls back to a system default with no error.
# Installed by cask "font-monaspace-nerd-font" in brew/Brewfile.core.
font-family = MonaspiceAr Nerd Font
background-opacity = 0.9
